# Copy to camera.env (in this directory) and fill in your values.
# camera.env is git-ignored.
#
# All runtime and verification scripts source this file:
#   CAMERA_IP   camera IPv4 on the LAN (e.g. 192.168.1.100)
#   CAMERA_USER Reolink username (usually `admin`)
#   CAMERA_PASS Reolink password

CAMERA_IP=192.168.1.100
CAMERA_USER=admin
CAMERA_PASS=your-password-here
